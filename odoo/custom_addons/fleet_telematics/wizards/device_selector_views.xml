<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fleet_device_selector_form" model="ir.ui.view">
        <field name="name">fleet.telematics.device.selector.form</field>
        <field name="model">fleet.telematics.device.selector</field>
        <field name="arch" type="xml">
            <form string="เลือก Device จาก Backend">
                <sheet>
                    <div class="oe_title">
                        <h2>🔌 เลือก GPS Device</h2>
                    </div>

                    <group>
                        <field name="vehicle_id"  readonly="1"/>
                        <field name="device_json" invisible="1"/>
                    </group>

                    <group string="รายการ Device จาก Backend">
                        <!-- Manual input (fallback) -->
                        <field name="selected_device_id"
                               string="Device ID"
                               placeholder="พิมพ์ Device ID หรือเลือกจากรายการด้านล่าง"/>
                    </group>

                    <!-- แสดงรายการ devices ที่โหลดมาในรูปแบบตาราง -->
                    <group string="รายการ Device ที่พบ">
                        <field name="device_json" widget="device_list_widget" invisible="1"/>
                    </group>

                    <!-- Dynamic HTML แสดง device list -->
                    <div class="o_field_widget">
                        <field name="device_json" invisible="1"/>
                        <div id="device_list_container"
                             style="max-height:300px; overflow-y:auto; border:1px solid #dee2e6; border-radius:4px; padding:8px;">
                            <em class="text-muted">รายการ device จะแสดงเมื่อโหลดสำเร็จ</em>
                        </div>
                    </div>

                </sheet>
                <footer>
                    <button name="action_confirm"
                            string="✅ บันทึก Device ID เท่านั้น"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_confirm_and_send"
                            string="✅ บันทึก + ส่ง Mapping ไป Backend"
                            type="object"
                            class="btn-primary"/>
                    <button string="ยกเลิก"
                            class="btn-default"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
