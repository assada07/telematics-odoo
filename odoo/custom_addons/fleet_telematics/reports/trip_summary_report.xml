<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_trip_summary" model="ir.actions.report">
        <field name="name">Trip Summary Report</field>
        <field name="model">fleet.telematics.log</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">fleet_telematics.report_trip_summary</field>
        <field name="report_file">fleet_telematics.report_trip_summary</field>
        <field name="binding_model_id" ref="model_fleet_telematics_log"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <template id="report_trip_summary">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <style>
                        .trip-header { background: #2E7D5E; color: white; padding: 8px 12px; margin-bottom: 16px; }
                        .trip-header h2 { margin: 0; font-size: 18px; }
                        .trip-header span { font-size: 12px; opacity: 0.85; }
                        .kpi-row { display: flex; gap: 12px; margin-bottom: 16px; }
                        .kpi-box { flex: 1; border: 1px solid #ddd; border-radius: 6px; padding: 10px; text-align: center; }
                        .kpi-box .val { font-size: 22px; font-weight: 600; color: #2E7D5E; }
                        .kpi-box .lbl { font-size: 10px; color: #888; }
                        .score-badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-weight: 600; font-size: 14px; }
                        .score-a { background: #d4edda; color: #155724; }
                        .score-b { background: #d1ecf1; color: #0c5460; }
                        .score-c { background: #fff3cd; color: #856404; }
                        .score-d { background: #f8d7da; color: #721c24; }
                        table.events { width: 100%; border-collapse: collapse; font-size: 11px; margin-top: 8px; }
                        table.events th { background: #f0f0f0; padding: 4px 8px; text-align: left; }
                        table.events td { padding: 4px 8px; border-bottom: 1px solid #eee; }
                        .page-break { page-break-after: always; }
                    </style>

                    <t t-foreach="docs" t-as="doc">
                        <div class="trip-header">
                            <h2>Trip Report: <t t-esc="doc.display_name"/></h2>
                            <span>External ID: <t t-esc="doc.external_trip_id or '-'"/></span>
                        </div>

                        <!-- KPI row -->
                        <div class="kpi-row">
                            <div class="kpi-box">
                                <div class="val"><t t-esc="'%.1f' % (doc.distance_km or 0)"/></div>
                                <div class="lbl">Distance (km)</div>
                            </div>
                            <div class="kpi-box">
                                <div class="val"><t t-esc="'%.0f' % (doc.duration_min or 0)"/></div>
                                <div class="lbl">Duration (min)</div>
                            </div>
                            <div class="kpi-box">
                                <div class="val"><t t-esc="'%.1f' % (doc.avg_speed or 0)"/></div>
                                <div class="lbl">Avg Speed (km/h)</div>
                            </div>
                            <div class="kpi-box">
                                <div class="val"><t t-esc="'%.1f' % (doc.max_speed or 0)"/></div>
                                <div class="lbl">Max Speed (km/h)</div>
                            </div>
                            <div class="kpi-box">
                                <div class="val"><t t-esc="'%.2f' % (doc.fuel_used_est or 0)"/></div>
                                <div class="lbl">Fuel Est. (L)</div>
                            </div>
                        </div>

                        <!-- Score + Harsh -->
                        <table style="width:100%; border-collapse:collapse; margin-bottom:16px;">
                            <tr>
                                <td style="width:50%; vertical-align:top; padding-right:12px;">
                                    <strong>Driver Score</strong><br/>
                                    <t t-set="sc" t-value="doc.driver_score or 0"/>
                                    <span t-attf-class="score-badge #{
                                        'score-a' if sc >= 90 else
                                        'score-b' if sc >= 75 else
                                        'score-c' if sc >= 60 else 'score-d'}">
                                        <t t-esc="'%.1f' % sc"/>
                                    </span>
                                    <br/><br/>
                                    <strong>Driver:</strong> <t t-esc="doc.driver_id.name or '-'"/><br/>
                                    <strong>Vehicle:</strong> <t t-esc="doc.vehicle_id.name or '-'"/><br/>
                                    <strong>Trip Start:</strong> <t t-esc="doc.trip_start"/><br/>
                                    <strong>Trip End:</strong>   <t t-esc="doc.trip_end or '-'"/><br/>
                                    <strong>Idle Time:</strong>  <t t-esc="'%.1f' % (doc.idle_min or 0)"/> min<br/>
                                </td>
                                <td style="width:50%; vertical-align:top;">
                                    <strong>Harsh Events</strong>
                                    <table style="width:100%; margin-top:6px; font-size:12px;">
                                        <tr><td>🛑 Harsh Brake</td><td><t t-esc="doc.harsh_brake_count or 0"/></td></tr>
                                        <tr><td>🚀 Harsh Accel</td><td><t t-esc="doc.harsh_accel_count or 0"/></td></tr>
                                        <tr><td>↩ Harsh Corner</td><td><t t-esc="doc.harsh_corner_count or 0"/></td></tr>
                                        <tr><td>⚡ Speeding</td><td><t t-esc="doc.speeding_count or 0"/></td></tr>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- Events table -->
                        <t t-if="doc.event_ids">
                            <strong>Event Detail</strong>
                            <table class="events">
                                <thead>
                                    <tr>
                                        <th>Time</th><th>Event</th>
                                        <th>Severity</th><th>Speed (km/h)</th>
                                        <th>Lat</th><th>Lon</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.event_ids" t-as="ev">
                                        <tr>
                                            <td><t t-esc="ev.occurred_at"/></td>
                                            <td><t t-esc="ev.event_type"/></td>
                                            <td><t t-esc="'%.1f' % (ev.severity or 0)"/></td>
                                            <td><t t-esc="'%.1f' % (ev.speed_at_event or 0)"/></td>
                                            <td><t t-esc="'%.5f' % (ev.lat or 0)"/></td>
                                            <td><t t-esc="'%.5f' % (ev.lon or 0)"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>

                        <t t-if="not doc_last">
                            <div class="page-break"/>
                        </t>
                    </t>
                </div>
            </t>
        </t>
    </template>

</odoo>
