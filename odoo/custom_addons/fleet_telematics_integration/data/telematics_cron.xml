<?xml version="1.0" encoding="utf-8"?>
<!--
  data/telematics_cron.xml
  Scheduled Actions (Cron Jobs)

  UC-04: Cron ดึง Trip Logs → เรียก fleet.telematics.log._cron_sync_trips()
         Logic ทั้งหมด (window time, dedup 3 ชั้น, batch 5 วินาที)
         อยู่ใน models/telematics_log.py section [I]–[N]
-->
<odoo>

    <!-- UC-04: ดึง Trip Logs ทุก 5 นาที — model: fleet.telematics.log -->
    <record id="ir_cron_telematics_sync_5min" model="ir.cron">
        <field name="name">Fleet Telematics: Sync Trips (5 min)</field>
        <field name="model_id" ref="model_fleet_telematics_log"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_trips()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>

    <!-- คำนวณโบนัสรายเดือน ทุกวันที่ 1 -->
    <record id="ir_cron_telematics_monthly_incentive" model="ir.cron">
        <field name="name">Fleet Telematics: Monthly Incentive</field>
        <field name="model_id" ref="model_fleet_telematics_incentive"/>
        <field name="state">code</field>
        <field name="code">model._cron_calculate_monthly_incentive()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>

</odoo>
