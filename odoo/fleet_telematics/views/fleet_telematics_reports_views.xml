<?xml version="1.0" encoding="utf-8"?>
<!--
  views/fleet_telematics_reports_views.xml
  หน้า Reports — Driver Score, Fuel Efficiency, Maintenance Cost,
  Fleet Summary, Incentive Summary พร้อม export PDF/Excel/Graph
-->
<odoo>

    <!-- ── Driver Score Report ────────────────────────────────────────── -->
    <record id="action_report_driver_score_view" model="ir.actions.act_window">
        <field name="name">Driver Score Report</field>
        <field name="res_model">fleet.telematics.incentive</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="context">{'search_default_group_driver': 1}</field>
    </record>

    <!-- ── Fuel Efficiency Report ─────────────────────────────────────── -->
    <record id="view_fuel_efficiency_pivot" model="ir.ui.view">
        <field name="name">fleet.telematics.log.pivot.fuel</field>
        <field name="model">fleet.telematics.log</field>
        <field name="arch" type="xml">
            <pivot string="Fuel Efficiency Report" sample="1">
                <field name="driver_id"    type="row"/>
                <field name="trip_start"   type="col" interval="month"/>
                <field name="fuel_used_est" type="measure"/>
                <field name="distance_km"   type="measure"/>
                <field name="idle_min"      type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_report_fuel_efficiency" model="ir.actions.act_window">
        <field name="name">Fuel Efficiency Report</field>
        <field name="res_model">fleet.telematics.log</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{'search_default_synced': 1}</field>
        <field name="search_view_id" ref="fleet_telematics.view_fleet_telematics_log_search"/>
    </record>

    <!-- ── Fleet Summary Report ───────────────────────────────────────── -->
    <record id="view_fleet_summary_pivot" model="ir.ui.view">
        <field name="name">fleet.telematics.log.pivot.fleet_summary</field>
        <field name="model">fleet.telematics.log</field>
        <field name="arch" type="xml">
            <pivot string="Fleet Summary" sample="1">
                <field name="vehicle_id"         type="row"/>
                <field name="trip_start"         type="col" interval="month"/>
                <field name="distance_km"        type="measure"/>
                <field name="driver_score"       type="measure"/>
                <field name="fuel_used_est"      type="measure"/>
                <field name="harsh_brake_count"  type="measure"/>
                <field name="speeding_count"     type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_report_fleet_summary" model="ir.actions.act_window">
        <field name="name">Fleet Summary</field>
        <field name="res_model">fleet.telematics.log</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{'search_default_synced': 1}</field>
    </record>

    <!-- ── Incentive Summary Report ───────────────────────────────────── -->
    <record id="action_report_incentive_summary" model="ir.actions.act_window">
        <field name="name">Incentive Summary Report</field>
        <field name="res_model">fleet.telematics.incentive</field>
        <field name="view_mode">pivot,list</field>
    </record>

    <!-- ── Maintenance Cost Report ────────────────────────────────────── -->
    <record id="action_report_maintenance_cost" model="ir.actions.act_window">
        <field name="name">Maintenance Cost Trend</field>
        <field name="res_model">fleet.telematics.maintenance</field>
        <field name="view_mode">graph,pivot,list</field>
    </record>

</odoo>
