<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List View ─────────────────────────────────────────────────── -->
    <record id="view_fleet_maintenance_list" model="ir.ui.view">
        <field name="name">fleet.telematics.maintenance.list</field>
        <field name="model">fleet.telematics.maintenance</field>
        <field name="arch" type="xml">
            <tree default_order="service_date desc"
                  decoration-danger="alert_status=='overdue'"
                  decoration-warning="alert_status=='due'"
                  decoration-success="alert_status=='ok'">
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <field name="service_date"/>
                <field name="mileage_km"/>
                <field name="cost"/>
                <field name="next_service_km"   optional="show"/>
                <field name="next_service_date" optional="show"/>
                <field name="technician"        optional="hide"/>
                <field name="alert_status"      widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- ── Form View ─────────────────────────────────────────────────── -->
    <record id="view_fleet_maintenance_form" model="ir.ui.view">
        <field name="name">fleet.telematics.maintenance.form</field>
        <field name="model">fleet.telematics.maintenance</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="ข้อมูลการซ่อมบำรุง">
                            <field name="vehicle_id"/>
                            <field name="service_type"/>
                            <field name="service_date"/>
                            <field name="mileage_km"/>
                            <field name="cost"/>
                            <field name="technician"/>
                        </group>
                        <group string="การซ่อมครั้งถัดไป">
                            <field name="next_service_km"/>
                            <field name="next_service_date"/>
                            <field name="alert_status" readonly="1" widget="badge"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="หมายเหตุ / รายละเอียดการซ่อม..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search View ───────────────────────────────────────────────── -->
    <record id="view_fleet_maintenance_search" model="ir.ui.view">
        <field name="name">fleet.telematics.maintenance.search</field>
        <field name="model">fleet.telematics.maintenance</field>
        <field name="arch" type="xml">
            <search>
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <filter name="overdue"  string="Overdue"   domain="[('alert_status','=','overdue')]"/>
                <filter name="due_soon" string="Due Soon"  domain="[('alert_status','=','due')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_vehicle" string="Vehicle"      context="{'group_by':'vehicle_id'}"/>
                    <filter name="group_type"    string="Service Type" context="{'group_by':'service_type'}"/>
                    <filter name="group_month"   string="Month"        context="{'group_by':'service_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Graph: Cost Trend ─────────────────────────────────────────── -->
    <record id="view_fleet_maintenance_graph" model="ir.ui.view">
        <field name="name">fleet.telematics.maintenance.graph</field>
        <field name="model">fleet.telematics.maintenance</field>
        <field name="arch" type="xml">
            <graph string="Maintenance Cost Trend" type="bar" sample="1">
                <field name="service_date" type="row" interval="month"/>
                <field name="cost"         type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ── Actions ───────────────────────────────────────────────────── -->
    <record id="action_fleet_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">fleet.telematics.maintenance</field>
        <field name="view_mode">list,form,graph</field>
        <field name="search_view_id" ref="view_fleet_maintenance_search"/>
    </record>

    <record id="action_fleet_maintenance_alert" model="ir.actions.act_window">
        <field name="name">Maintenance Alerts</field>
        <field name="res_model">fleet.telematics.maintenance</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('alert_status','in',['overdue','due'])]</field>
        <field name="search_view_id" ref="view_fleet_maintenance_search"/>
    </record>

    <record id="action_fleet_maintenance_cost_trend" model="ir.actions.act_window">
        <field name="name">Maintenance Cost Trend</field>
        <field name="res_model">fleet.telematics.maintenance</field>
        <field name="view_mode">graph,list</field>
    </record>

</odoo>
