<?xml version="1.0" encoding="utf-8"?>
<!--
  views/fleet_telematics_sync_board_views.xml
  Sync Board: แสดง Mapping รถ ↔ คนขับ ↔ Device
  เลือกรถ → ดึงข้อมูลอัตโนมัติ, เปลี่ยนสถานะ sync ได้
-->
<odoo>

    <!-- ── List View (Sync Board หลัก) ───────────────────────────────── -->
    <record id="view_fleet_telematics_mapping_tree" model="ir.ui.view">
        <field name="name">fleet.telematics.vehicle.mapping.tree</field>
        <field name="model">fleet.telematics.vehicle.mapping</field>
        <field name="arch" type="xml">
            <tree string="Sync Board"
                  decoration-success="sync_status == 'active'"
                  decoration-muted="sync_status == 'inactive'"
                  decoration-warning="sync_status == 'pending'">
                <field name="vehicle_id"          string="Vehicle"/>
                <field name="license_plate"       string="ทะเบียน"/>
                <field name="model_name"          string="รุ่นรถ" optional="show"/>
                <field name="driver_id"           string="คนขับ"/>
                <field name="driver_phone"        string="เบอร์โทร" optional="show"/>
                <field name="driver_job"          string="ตำแหน่ง" optional="show"/>
                <field name="telematics_device_id" string="Device ID"/>
                <field name="sync_status"         string="สถานะ" widget="badge"
                       decoration-success="sync_status == 'active'"
                       decoration-danger="sync_status == 'inactive'"
                       decoration-warning="sync_status == 'pending'"/>
                <field name="last_sync_at"        string="Sync ล่าสุด" optional="show"/>
                <button name="action_activate"   string="Activate"   type="object"
                        class="btn-success btn-sm"
                        invisible="sync_status == 'active'"/>
                <button name="action_deactivate" string="Deactivate" type="object"
                        class="btn-secondary btn-sm"
                        invisible="sync_status != 'active'"/>
            </tree>
        </field>
    </record>

    <!-- ── Form View ─────────────────────────────────────────────────── -->
    <record id="view_fleet_telematics_mapping_form" model="ir.ui.view">
        <field name="name">fleet.telematics.vehicle.mapping.form</field>
        <field name="model">fleet.telematics.vehicle.mapping</field>
        <field name="arch" type="xml">
            <form string="Config — Vehicle / Driver Mapping">
                <header>
                    <button name="action_activate"   string="✅ Activate"
                            type="object" class="btn-primary"
                            invisible="sync_status == 'active'"/>
                    <button name="action_deactivate" string="⛔ Deactivate"
                            type="object" class="btn-secondary"
                            invisible="sync_status != 'active'"/>
                    <field name="sync_status" widget="statusbar"
                           statusbar_visible="pending,active,inactive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="vehicle_id"
                                   placeholder="เลือกรถ..."
                                   options="{'no_create': True}"/>
                        </h1>
                    </div>

                    <group>
                        <!-- ซ้าย: ข้อมูลรถ (ดึงอัตโนมัติจาก vehicle) -->
                        <group string="🚗 ข้อมูลรถ">
                            <field name="license_plate"       string="ทะเบียน"/>
                            <field name="model_name"          string="รุ่นรถ" readonly="1"/>
                            <field name="telematics_device_id" string="Device ID (GPS)"/>
                        </group>

                        <!-- ขวา: ข้อมูลคนขับ (ดึงอัตโนมัติ หรือเลือกได้) -->
                        <group string="👤 ข้อมูลคนขับ">
                            <field name="driver_id"   string="คนขับ"
                                   options="{'no_create': True}"/>
                            <field name="driver_phone" string="เบอร์โทร" readonly="1"/>
                            <field name="driver_job"   string="ตำแหน่ง"  readonly="1"/>
                        </group>
                    </group>

                    <group string="ℹ️ สถานะ Sync">
                        <field name="last_sync_at" readonly="1"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search View ───────────────────────────────────────────────── -->
    <record id="view_fleet_telematics_mapping_search" model="ir.ui.view">
        <field name="name">fleet.telematics.vehicle.mapping.search</field>
        <field name="model">fleet.telematics.vehicle.mapping</field>
        <field name="arch" type="xml">
            <search>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="telematics_device_id"/>
                <filter name="active"   string="🟢 Active"   domain="[('sync_status','=','active')]"/>
                <filter name="inactive" string="⚫ Inactive" domain="[('sync_status','=','inactive')]"/>
                <filter name="pending"  string="🟡 Pending"  domain="[('sync_status','=','pending')]"/>
                <group expand="1" string="Group By">
                    <filter name="group_status" string="Sync Status"
                            context="{'group_by': 'sync_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────── -->
    <record id="action_fleet_telematics_sync_board" model="ir.actions.act_window">
        <field name="name">Sync Board</field>
        <field name="res_model">fleet.telematics.vehicle.mapping</field>
        <field name="view_mode">tree,form</field>
        <field name="target">main</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                เพิ่ม Mapping รถ ↔ คนขับ
            </p>
            <p>
                เลือกรถ แล้วระบบจะดึงข้อมูลคนขับ ทะเบียน และ Device มาให้อัตโนมัติ
            </p>
        </field>
    </record>

</odoo>
