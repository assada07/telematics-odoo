<?xml version="1.0" encoding="utf-8"?>
<!--
  views/fleet_telematics_dashboard_views.xml
  Dashboard หน้าหลัก — KPI Summary, Driver Scorecard, Energy Summary,
  Incentive Summary, Fleet Live Map (embedded widget)
-->
<odoo>

    <!-- ── Dashboard Action (Graph+Pivot+List แบบ multi-mode) ───────── -->
    <record id="action_fleet_dashboard_main" model="ir.actions.act_window">
        <field name="name">Fleet Dashboard</field>
        <field name="res_model">fleet.telematics.log</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="context">{
            'search_default_synced': 1,
            'search_default_this_month': 1
        }</field>
        <field name="search_view_id" ref="fleet_telematics.view_fleet_telematics_log_search"/>
    </record>

    <!-- ── KPI Summary: trips, avg score, events, online vehicles ────── -->
    <record id="action_fleet_kpi_trips" model="ir.actions.act_window">
        <field name="name">Trip Count</field>
        <field name="res_model">fleet.telematics.log</field>
        <field name="view_mode">list,graph</field>
        <field name="context">{'search_default_synced': 1}</field>
    </record>

    <record id="action_fleet_kpi_events" model="ir.actions.act_window">
        <field name="name">Events Summary</field>
        <field name="res_model">fleet.telematics.event</field>
        <field name="view_mode">list,graph</field>
    </record>

    <!-- ── Driver Scorecard ────────────────────────────────────────── -->
    <record id="action_fleet_driver_scorecard" model="ir.actions.act_window">
        <field name="name">Driver Scorecard</field>
        <field name="res_model">fleet.telematics.log</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="context">{
            'search_default_synced': 1,
            'group_by': 'driver_id'
        }</field>
        <field name="search_view_id" ref="fleet_telematics.view_fleet_telematics_log_search"/>
    </record>

    <!-- ── Energy / Fuel Summary ──────────────────────────────────── -->
    <record id="view_fleet_fuel_graph" model="ir.ui.view">
        <field name="name">fleet.telematics.log.graph.fuel</field>
        <field name="model">fleet.telematics.log</field>
        <field name="arch" type="xml">
            <graph string="Fuel &amp; Idle Summary" type="bar" sample="1">
                <field name="driver_id"    type="row"/>
                <field name="fuel_used_est" type="measure"/>
                <field name="idle_min"      type="measure"/>
                <field name="distance_km"   type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_fleet_fuel_summary" model="ir.actions.act_window">
        <field name="name">Energy / Fuel Summary</field>
        <field name="res_model">fleet.telematics.log</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="context">{'search_default_synced': 1}</field>
    </record>

    <!-- ── Incentive Summary (shortcut) ────────────────────────────── -->
    <record id="action_fleet_incentive_summary_dash" model="ir.actions.act_window">
        <field name="name">Incentive Summary</field>
        <field name="res_model">fleet.telematics.incentive</field>
        <field name="view_mode">pivot,list</field>
    </record>

    <!-- ── Fleet Live Map (vehicle status list fallback) ────────────── -->
    <record id="action_fleet_live_map" model="ir.actions.act_window">
        <field name="name">Fleet Live Map</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('telematics_device_id','!=',False)]</field>
        <field name="context">{'search_default_online': 1}</field>
    </record>

</odoo>
