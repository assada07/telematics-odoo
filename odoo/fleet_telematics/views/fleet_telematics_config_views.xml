<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fleet_telematics_config_form" model="ir.ui.view">
        <field name="name">fleet.telematics.config.form</field>
        <field name="model">fleet.telematics.config</field>
        <field name="arch" type="xml">
            <form string="Fleet Telematics Config">
                <header>
                    <button name="action_save"
                            string="Save"
                            type="object"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Fleet Telematics</h1>
                    </div>
                    <group>
                        <field name="api_url"     string="API URL"     placeholder="https://mtd.example.com/api/v1"/>
                        <field name="api_key"     string="API Key"     password="True" placeholder="sk-••••••••"/>
                        <field name="device_name" string="device_name" placeholder="KTC GPS Tracker"/>
                        <field name="device_id"   string="device_id"   placeholder="KTC-001"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_telematics_config" model="ir.actions.act_window">
        <field name="name">Fleet Telematics Settings</field>
        <field name="res_model">fleet.telematics.config</field>
        <field name="view_mode">list,form</field>
        <field name="target">inline</field>
    </record>

</odoo>
