<?xml version="1.0" encoding="utf-8"?>
<!--
  views/telematics_menus.xml
  ไฟล์สร้างแถบเมนูหลักและเมนูย่อยของ Fleet Telematics
  โครงสร้างตรงตาม UI Structure ที่กำหนด 100%

  Fleet Telematics (Root App)
  ├── Dashboard
  │   ├── KPI Summary
  │   ├── Fuel & Energy Analysis
  │   └── Incentive Overview
  ├── Trip Logs
  │   ├── Trip List
  │   └── Trip Analytics
  ├── Event Logs
  ├── Scoring Config
  ├── Incentive / Bonus
  ├── Reports (Export PDF/Excel)
  └── Settings
-->
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  Root App — Fleet Telematics                                   -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_fleet_telematics_root"
              name="Fleet Telematics"
              sequence="80"
              web_icon="fleet_telematics_integration,static/description/icon.png"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  2.1 Dashboard                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_telematics_dashboard"
              name="Dashboard"
              parent="menu_fleet_telematics_root"
              sequence="10"/>

    <!-- KPI Summary: จำนวนทริป, คะแนนเฉลี่ย, พฤติกรรมเสี่ยง -->
    <menuitem id="menu_telematics_dashboard_kpi"
              name="KPI Summary"
              parent="menu_telematics_dashboard"
              action="action_telematics_dashboard"
              sequence="10"/>

    <!-- Fuel &amp; Energy Analysis: Fuel Usage, Fuel/km, Idle Time -->
    <menuitem id="menu_telematics_dashboard_fuel"
              name="Fuel &amp; Energy Analysis"
              parent="menu_telematics_dashboard"
              action="action_telematics_fuel_summary"
              sequence="20"/>

    <!-- Incentive Overview: กราฟแท่งโบนัส + สัดส่วน Tier -->
    <menuitem id="menu_telematics_dashboard_incentive"
              name="Incentive Overview"
              parent="menu_telematics_dashboard"
              action="action_telematics_incentive_summary"
              sequence="30"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  2.2 Trip Logs                                                  -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_telematics_trip_logs"
              name="Trip Logs"
              parent="menu_fleet_telematics_root"
              sequence="20"/>

    <!-- Trip List — ตารางรวม + Sync Status -->
    <menuitem id="menu_telematics_trip_list"
              name="Trip List"
              parent="menu_telematics_trip_logs"
              action="action_telematics_log"
              sequence="10"/>

    <!-- Trip Analytics — Graph + Pivot -->
    <menuitem id="menu_telematics_trip_analytics"
              name="Trip Analytics"
              parent="menu_telematics_trip_logs"
              action="action_telematics_analytics"
              sequence="20"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  2.3 Event Logs                                                 -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_telematics_event_logs"
              name="Event Logs"
              parent="menu_fleet_telematics_root"
              action="action_telematics_event"
              sequence="30"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  2.4 Scoring Config                                             -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_telematics_scoring_config"
              name="Scoring Config"
              parent="menu_fleet_telematics_root"
              action="action_telematics_scoring_config"
              sequence="40"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  2.5 Incentive / Bonus                                          -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_telematics_incentive"
              name="Incentive / Bonus"
              parent="menu_fleet_telematics_root"
              action="action_telematics_incentive"
              sequence="50"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  2.6 Reports — Export PDF / Excel                               -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_telematics_reports"
              name="Reports"
              parent="menu_fleet_telematics_root"
              sequence="60"/>

    <!-- Driver Score Report -->
    <menuitem id="menu_telematics_report_driver_score"
              name="Driver Score Report"
              parent="menu_telematics_reports"
              action="action_telematics_incentive"
              sequence="10"/>

    <!-- Fuel Efficiency Report -->
    <menuitem id="menu_telematics_report_fuel"
              name="Fuel Efficiency Report"
              parent="menu_telematics_reports"
              action="action_telematics_fuel_summary"
              sequence="20"/>

    <!-- Fleet Summary -->
    <menuitem id="menu_telematics_report_fleet_summary"
              name="Fleet Summary"
              parent="menu_telematics_reports"
              action="action_telematics_analytics"
              sequence="30"/>

    <!-- Incentive Summary -->
    <menuitem id="menu_telematics_report_incentive"
              name="Incentive Summary"
              parent="menu_telematics_reports"
              action="action_telematics_incentive_summary"
              sequence="40"/>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  Settings — Fleet Telematics API Config                         -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <menuitem id="menu_telematics_settings"
              name="Settings"
              parent="menu_fleet_telematics_root"
              action="fleet_telematics_integration.action_open_telematics_config"
              sequence="99"/>

</odoo>
